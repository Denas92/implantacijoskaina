# Vieši kintamieji (įkeliami į naršyklę — tik NEXT_PUBLIC_*)
# Google Tag Manager (GTM-XXXXXXX) — įdėkite konteinerio ID
# NEXT_PUBLIC_GTM_ID=

NEXT_PUBLIC_CLINIC_PHONE=+37060000000
NEXT_PUBLIC_CLINIC_PHONE_DISPLAY=+370 600 00000
NEXT_PUBLIC_WHATSAPP_PHONE=37060000000

# Sanity — numatyta 9dzpnf19 (tas pats Studio + svetainė). Kitu atveju įrašykite kitą ID.
# NEXT_PUBLIC_SANITY_PROJECT_ID=9dzpnf19
NEXT_PUBLIC_SANITY_DATASET=production
# Vienintelė Studio šiame repo: npm run studio → http://localhost:3333
#
# Pradiniai įrašai į dataset (npm run sanity:seed):
#   1) sanity.io/manage → API → Tokens → Editor token
#   2) SANITY_API_WRITE_TOKEN=sk… (į .env.local, necommitinti)
#   Jei esate „Project member“, galite: npx sanity login && npm run sanity:seed:login

# Resend — https://resend.com/api-keys
# Siuntėjas turi būti iš patvirtinto domeno Resend (pvz. noreply@jūsų-domenas.lt)
RESEND_API_KEY=
# Pvz. "Implantacijos kaina <noreply@implantacijoskaina.lt>"
RESEND_FROM_EMAIL=
# Galima perrašyti (numatytasis — denas@skaitmeninessypsenos.lt)
# CONTACT_LEAD_TO=denas@skaitmeninessypsenos.lt
